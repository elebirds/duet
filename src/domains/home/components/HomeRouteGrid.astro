---
import { Icon } from "astro-icon/components";
import type { FeaturedRouteConfig } from "../../../types/config";

interface Props {
	routes: FeaturedRouteConfig[];
}

const { routes } = Astro.props;
---

<section class="flex flex-col gap-4">
	<div class="px-1">
		<div class="portal-kicker">
			Routes
		</div>
		<h2 class="mt-2 text-2xl font-bold text-black/90 transition dark:text-white/90">
			Choose a thread to continue
		</h2>
	</div>
	<div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
		{routes.map((route, index) => (
			<a
				href={route.href}
				class="card-base portal-panel group flex min-h-48 flex-col justify-between rounded-[var(--radius-large)] p-5 transition hover:-translate-y-1"
			>
				<div class="flex items-center justify-between gap-3">
					<div class="text-[0.7rem] font-semibold uppercase tracking-[0.24em] text-black/40 transition dark:text-white/40">
					{String(index + 1).padStart(2, "0")}
					</div>
					<span class="portal-chip">Open route</span>
				</div>
				<div class="mt-8">
					<div class="flex items-center justify-between gap-3">
						<h3 class="text-xl font-bold text-black/90 transition dark:text-white/90">
							{route.title}
						</h3>
						<Icon
							name="fa6-solid:arrow-up-right-from-square"
							class="text-sm text-black/30 transition group-hover:text-[var(--primary)] dark:text-white/30"
						/>
					</div>
					<p class="mt-3 text-sm leading-6 text-black/65 transition dark:text-white/65">
						{route.description}
					</p>
				</div>
			</a>
		))}
	</div>
</section>
