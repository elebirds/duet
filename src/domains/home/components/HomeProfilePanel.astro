---
import { Icon } from "astro-icon/components";
import ImageWrapper from "../../../components/misc/ImageWrapper.astro";
import type { ProfileConfig } from "../../../types/config";

interface Props {
	profile: ProfileConfig;
}

const { profile } = Astro.props;
---

<section class="card-base rounded-[var(--radius-large)] p-5 md:p-6">
	<div class="flex items-start gap-4">
		<div class="h-20 w-20 overflow-hidden rounded-2xl">
			<ImageWrapper
				src={profile.avatar || ""}
				alt={`Profile image of ${profile.name}`}
				class="h-full w-full"
			/>
		</div>
		<div class="min-w-0 flex-1">
			<div class="text-[0.7rem] font-semibold uppercase tracking-[0.24em] text-black/45 transition dark:text-white/45">
				Profile
			</div>
			<h2 class="mt-2 text-2xl font-bold text-black/90 transition dark:text-white/90">
				{profile.name}
			</h2>
			{profile.bio && (
				<p class="mt-2 text-sm leading-6 text-black/65 transition dark:text-white/65">
					{profile.bio}
				</p>
			)}
		</div>
	</div>
	{
		profile.links.length > 0 && (
			<div class="mt-5 flex flex-wrap gap-2">
				{profile.links.map((item) => (
					<a
						rel="me"
						aria-label={item.name}
						href={item.url}
						target="_blank"
						class="btn-regular flex h-10 items-center gap-2 rounded-lg px-3 active:scale-95"
					>
						<Icon name={item.icon} class="text-[1.25rem]" />
						<span class="text-sm font-medium">{item.name}</span>
					</a>
				))}
			</div>
		)
	}
</section>
