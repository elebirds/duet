# GitHub OAuth for private moments and posts
# Local callback URL: http://localhost:4321/auth/callback/
DUET_GITHUB_CLIENT_ID=your-github-oauth-app-client-id
DUET_GITHUB_CLIENT_SECRET=your-github-oauth-app-client-secret
DUET_SESSION_SECRET=replace-with-a-long-random-string
DUET_GITHUB_ALLOWLIST=your-github-login

# Optional content source overrides
DUET_CONTENT_LOCAL_PATH=
DUET_CONTENT_REPO=
CONTENT_REPO_TOKEN=
